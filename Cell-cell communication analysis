# ==============================================================================
# Cell-Cell Communication Analysis (CellChat)
# Workflow: Separate NL(Control) & LS(KO) group, run CellChat individually, merge & compare signaling networks
# Output: Circle plot, comparison barplot, pathway heatmap, signaling role heatmap, ligand-receptor bubble plot
# Dependencies: Seurat, SeuratObject, CellChat
# Input: Integrated seurat object sc_data (mouse single-cell data)
# ==============================================================================
library(Seurat)
library(SeuratObject)
library(CellChat)

# Create output directory to avoid path error
if (!dir.exists("./cell_communication_result")) dir.create("./cell_communication_result")

# ===================== Step 1: Load integrated seurat object & normalization =====================
merged_data <- readRDS("./sc_data_last4.0.rds")
merged_data <- NormalizeData(merged_data, normalization.method = "LogNormalize")

# Label condition: Abhd5_KO = LS, Control = NL
merged_data$condition <- ifelse(merged_data$group == "Abhd5_KO", "LS", "NL")

# ===================== Step 2: Run CellChat for LS (KO group) =====================
# Extract normalized expression & metadata for LS samples
data.input_ko <- merged_data@assays$RNA@data
meta_ko <- merged_data@meta.data
cell_use_ko <- rownames(meta_ko)[meta_ko$condition == "LS"]
data.input_ko <- data.input_ko[, cell_use_ko]
meta_ko <- meta_ko[cell_use_ko, ]

# Build CellChat object
ko_cellchat <- createCellChat(
  object = data.input_ko,
  meta = meta_ko,
  group.by = "celltype"
)
ko_cellchat <- setIdent(ko_cellchat, ident.use = "celltype")

# Assign mouse CellChat database
CellChatDB <- CellChatDB.mouse
ko_cellchat@DB <- CellChatDB

# Standard CellChat workflow
ko_cellchat <- subsetData(ko_cellchat)
ko_cellchat <- identifyOverExpressedGenes(
  ko_cellchat,
  only.pos = TRUE,
  thresh.pc = 0.1,
  thresh.fc = 0.25,
  thresh.p = 0.05
)
ko_cellchat <- identifyOverExpressedInteractions(ko_cellchat)
ko_cellchat <- computeCommunProb(ko_cellchat, raw.use = TRUE)
ko_cellchat <- filterCommunication(ko_cellchat, min.cells = 10)

# Extract communication table
df.net_ko <- subsetCommunication(ko_cellchat)
ko_cellchat <- computeCommunProbPathway(ko_cellchat)
df.netp_ko <- subsetCommunication(ko_cellchat, slot.name = "netP")
ko_cellchat <- aggregateNet(ko_cellchat)
groupsize_ko <- as.numeric(table(ko_cellchat@idents))

# Export circle plot for interaction count
pdf("./cell_communication_result/ko_cellchat_interaction_number.pdf", width = 10, height = 7)
par(mfrow = c(1, 1), xpd = TRUE)
netVisual_circle(
  ko_cellchat@net$count,
  vertex.weight = groupsize_ko,
  weight.scale = TRUE,
  label.edge = FALSE,
  title.name = "Number of interactions (LS/KO)"
)
dev.off()

# Export circle plot for interaction strength
pdf("./cell_communication_result/ko_cellchat_interaction_weight.pdf", width = 10, height = 7)
par(mfrow = c(1, 1), xpd = TRUE)
netVisual_circle(
  ko_cellchat@net$weight,
  vertex.weight = groupsize_ko,
  weight.scale = TRUE,
  label.edge = FALSE,
  title.name = "Interaction weights/strength (LS/KO)"
)
dev.off()

# ===================== Step 3: Run CellChat for NL (Control group) =====================
data.input_con <- merged_data@assays$RNA@data
meta_con <- merged_data@meta.data
cell_use_con <- rownames(meta_con)[meta_con$condition == "NL"]
data.input_con <- data.input_con[, cell_use_con]
meta_con <- meta_con[cell_use_con, ]

con_cellchat <- createCellChat(
  object = data.input_con,
  meta = meta_con,
  group.by = "celltype"
)
con_cellchat <- setIdent(con_cellchat, ident.use = "celltype")

con_cellchat@DB <- CellChatDB
con_cellchat <- subsetData(con_cellchat)
con_cellchat <- identifyOverExpressedGenes(
  con_cellchat,
  only.pos = TRUE,
  thresh.pc = 0.1,
  thresh.fc = 0.25,
  thresh.p = 0.05
)
con_cellchat <- identifyOverExpressedInteractions(con_cellchat)
con_cellchat <- computeCommunProb(con_cellchat, raw.use = TRUE)
con_cellchat <- filterCommunication(con_cellchat, min.cells = 10)

df.net_con <- subsetCommunication(con_cellchat)
con_cellchat <- computeCommunProbPathway(con_cellchat)
df.netp_con <- subsetCommunication(con_cellchat, slot.name = "netP")
con_cellchat <- aggregateNet(con_cellchat)
groupsize_con <- as.numeric(table(con_cellchat@idents))

# Control interaction circle plot
pdf("./cell_communication_result/wt_cellchat_interaction_number.pdf", width = 10, height = 7)
netVisual_circle(
  con_cellchat@net$count,
  vertex.weight = groupsize_con,
  weight.scale = TRUE,
  label.edge = FALSE,
  title.name = "Number of interactions (NL/Control)"
)
dev.off()

pdf("./cell_communication_result/wt_cellchat_interaction_weight.pdf", width = 10, height = 7)
par(mfrow = c(1, 1), xpd = TRUE)
netVisual_circle(
  con_cellchat@net$weight,
  vertex.weight = groupsize_con,
  weight.scale = TRUE,
  label.edge = FALSE,
  title.name = "Interaction weights/strength (NL/Control)"
)
dev.off()

# ===================== Step 4: Merge two CellChat objects for differential comparison =====================
cellchat.NL <- updateCellChat(con_cellchat)
cellchat.LS <- updateCellChat(ko_cellchat)
object.list <- list(NL = cellchat.NL, LS = cellchat.LS)

# Compute pathway centrality for both groups
object.list[[1]] <- netAnalysis_computeCentrality(object.list[[1]], slot.name = "netP")
object.list[[2]] <- netAnalysis_computeCentrality(object.list[[2]], slot.name = "netP")

# Merge object
cellchat_merge <- mergeCellChat(object.list, add.names = names(object.list))
comp_color <- c("#9EB4E0", "#E1846C")

# Compare total interaction number & weight
p_comp_num <- compareInteractions(cellchat_merge, show.legend = FALSE, group = c(1,2)) + scale_fill_manual(values = comp_color)
p_comp_weight <- compareInteractions(cellchat_merge, show.legend = FALSE, group = c(1,2), measure = "weight") + scale_fill_manual(values = comp_color)

pdf("./cell_communication_result/compare_interactions_number_weight.pdf", width = 8, height = 5)
p_comp_num + p_comp_weight
dev.off()

# Cell-cell interaction heatmap
p_heat_count <- netVisual_heatmap(cellchat_merge)
p_heat_weight <- netVisual_heatmap(cellchat_merge, measure = "weight")
pdf("./cell_communication_result/differential_interaction_heatmap.pdf", width = 12, height = 7)
p_heat_count + p_heat_weight
dev.off()

# Rank signaling pathways comparison
rank_color <- c("#E1846C", "#9EB4E0")
p_rank_stack <- rankNet(cellchat_merge, mode = "comparison", stacked = TRUE, do.stat = TRUE) + scale_fill_manual(values = rank_color)
p_rank_unstack <- rankNet(cellchat_merge, mode = "comparison", stacked = FALSE, do.stat = TRUE) + scale_fill_manual(values = rank_color)
pdf("./cell_communication_result/differential_signaling_pathway_rank.pdf", width = 12, height = 10)
p_rank_stack + p_rank_unstack
dev.off()

# Define union of all signaling pathways
pathway.union <- union(names(cellchat_merge@netP$pathways), names(object.list[[2]]@netP$pathways))

# Outgoing signaling role heatmap
ht_out_nl <- netAnalysis_signalingRole_heatmap(
  object.list[[1]],
  pattern = "outgoing",
  signaling = pathway.union,
  title = names(object.list)[1],
  width = 12, height = 20
)
ht_out_ls <- netAnalysis_signalingRole_heatmap(
  object.list[[2]],
  pattern = "outgoing",
  signaling = pathway.union,
  title = names(object.list)[2],
  width = 12, height = 20
)
pdf("./cell_communication_result/signaling_outgoing_heatmap.pdf", width = 12, height = 8)
ht_out_nl + ht_out_ls
dev.off()

# Incoming signaling role heatmap
ht_in_nl <- netAnalysis_signalingRole_heatmap(
  object.list[[1]],
  pattern = "incoming",
  signaling = pathway.union,
  title = names(object.list)[1],
  width = 12, height = 20,
  color.heatmap = "GnBu"
)
ht_in_ls <- netAnalysis_signalingRole_heatmap(
  object.list[[2]],
  pattern = "incoming",
  signaling = pathway.union,
  title = names(object.list)[2],
  width = 12, height = 20,
  color.heatmap = "GnBu"
)
pdf("./cell_communication_result/signaling_incoming_heatmap.pdf", width = 12, height = 8)
ht_in_nl + ht_in_ls
dev.off()

# All signaling role heatmap
ht_all_nl <- netAnalysis_signalingRole_heatmap(
  object.list[[1]],
  pattern = "all",
  signaling = pathway.union,
  title = names(object.list)[1],
  width = 12, height = 20,
  color.heatmap = "OrRd"
)
ht_all_ls <- netAnalysis_signalingRole_heatmap(
  object.list[[2]],
  pattern = "all",
  signaling = pathway.union,
  title = names(object.list)[2],
  width = 12, height = 20,
  color.heatmap = "OrRd"
)
pdf("./cell_communication_result/signaling_all_heatmap.pdf", width = 12, height = 8)
ht_all_nl + ht_all_ls
dev.off()

# ===================== Step 5: Ligand-receptor bubble plot for differential communication =====================
# Check all cell subtypes
levels(cellchat_merge@idents$joint)

# Global bubble plot across all cell groups
p_bubble_global <- netVisual_bubble(
  cellchat_merge,
  sources.use = 1:15,
  targets.use = 1:15,
  comparison = c(1, 2),
  angle.x = 45
)

# Bubble plot: signaling increased in LS/KO
p_bubble_up <- netVisual_bubble(
  cellchat_merge,
  sources.use = c(12,15),
  targets.use = c(15,24),
  comparison = c(1,2),
  max.dataset = 2,
  title.name = "Signaling increased in KO (LS)",
  angle.x = 90,
  remove.isolate = TRUE
)

# Bubble plot: signaling decreased in LS/KO
p_bubble_down <- netVisual_bubble(
  cellchat_merge,
  sources.use = 14:18,
  targets.use = 13,
  max.dataset = 1,
  title.name = "Signaling decreased in KO (LS)",
  angle.x = 90,
  remove.isolate = FALSE
)

# Combine two differential bubble plots
p_bubble_comb <- p_bubble_up + p_bubble_down
print(p_bubble_comb)

# Export bubble plot
pdf("./cell_communication_result/differential_ligand_receptor_bubble.pdf", width = 14, height = 8)
print(p_bubble_comb)
dev.off()
