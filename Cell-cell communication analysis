library(Seurat)
library(SeuratObject)
library(CellChat)
merged_data <- readRDS("./sc_data_last4.0.rds")
merged_data <- NormalizeData(merged_data,normalization.method = "LogNormalize")

merged_data$condition <- ifelse(merged_data$group=="Abhd5_KO",'LS',"NL")
data.input <- merged_data@assays$RNA@data
meta <- merged_data@meta.data
cell.use = rownames(meta)[meta$condition == 'LS'] 
data.input = data.input[, cell.use] 
meta = meta[cell.use,]
ko_cellchat <- createCellChat(object = data.input, #支持normalized表达矩阵，Seurat对象，和SingleCellExperiment对象
                              meta= meta, #meta文件
                              group.by = 'celltype')
ko_cellchat <- setIdent(ko_cellchat, ident.use = 'celltype')
CellChatDB <- CellChatDB.mouse # 小鼠数据库
# CellChatDB.use <- subsetDB(CellChatDB, search = "Secreted Signaling") 
ko_cellchat@DB <- CellChatDB   ##CellChatDB.use
#运行识别过表达基因
ko_cellchat <- subsetData(ko_cellchat) 
ko_cellchat <- identifyOverExpressedGenes(ko_cellchat,
                                          only.pos = TRUE, #仅返回positive markers
                                          thresh.pc = 0.1, #细胞比例阈值
                                          thresh.fc = 0.25, #差异倍数
                                          thresh.p = 0.05)
#识别过表达基因配体-受体互作：
ko_cellchat <- identifyOverExpressedInteractions(ko_cellchat)
ko_cellchat<- computeCommunProb(ko_cellchat, raw.use = TRUE)
ko_cellchat <- filterCommunication(ko_cellchat,min.cells = 10)
# ko_cellchat <- netAnalysis_computeCentrality(ko_cellchat)
####提取配受体对细胞通讯结果表
df.net=subsetCommunication(ko_cellchat)
ko_cellchat=computeCommunProbPathway(ko_cellchat)
df.netp=subsetCommunication(ko_cellchat,slot.name = "netP")
ko_cellchat=aggregateNet(ko_cellchat)
groupsize=as.numeric(table(ko_cellchat@idents))
pdf("./细胞通讯整体/ko_cellchat_num.pdf", width = 10, height = 7)
par(mfrow=c(1,1),xpd=T)
netVisual_circle(ko_cellchat@net$count,
                 vertex.weight = groupsize,
                 weight.scale = T,
                 label.edge = F,
                 title.name = "Number of interactions")
dev.off()
pdf("./细胞通讯整体//ko_cellchat_weight.pdf", width = 10, height = 7)
par(mfrow=c(1,1),xpd=T)
netVisual_circle(ko_cellchat@net$weight,
                 vertex.weight = groupsize,
                 weight.scale = T,
                 label.edge = F,
                 title.name = "Interaction weights/strength")
dev.off()
