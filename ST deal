#' Get counts from Seurat object (compatible with v4 and v5)
get_counts <- function(obj, assay_name) {
  # Try v5 layer first
  x <- tryCatch(
    GetAssayData(object = obj, assay = assay_name, slot = "counts"),
    error = function(e) NULL
  )
  if (!is.null(x)) return(x)
  
  # Fallback for v4
  x <- tryCatch(
    GetAssayData(object = obj, assay = assay_name, slot = "counts"),
    error = function(e) NULL
  )
  if (!is.null(x)) return(x)
  
  stop(sprintf("Cannot read counts from assay '%s'", assay_name))
}
#' Extract spatial coordinates from Seurat object
pick_coords_xy <- function(coords_df) {
  # Try common coordinate column names
  candidates <- list(
    c("row", "col"),
    c("x", "y"),
    c("imagerow", "imagecol")
  )
  selected <- NULL
  for (cn in candidates) {
    if (all(cn %in% colnames(coords_df))) {
      selected <- cn
      break
    }
  }  
  if (is.null(selected)) {
    stop("No valid coordinate columns found in image@coordinates")
  }
  xy <- coords_df[, selected, drop = FALSE]
  colnames(xy) <- c("x", "y")
  xy
}
#' Normalize weights from RCTD results
normalize_weights <- function(weights) {
  weights / rowSums(weights)
}
# ------------------------------------------------------------------------------
# 2.2 RCTD Functions
# ------------------------------------------------------------------------------
#' Run RCTD deconvolution and annotate Seurat object
run_rctd_and_annotate <- function(
    st_obj,
    reference,
    doublet_mode = "doublet",
    max_cores = 1,
    spatial_assay = "Spatial"
) {
  # Extract counts
  spatial_count <- get_counts(st_obj, spatial_assay)
  # Extract coordinates
  if (length(st_obj@images) < 1) {
    stop("ST object has no images.")
  }
  img_key <- names(st_obj@images)[1]
  coords_raw <- st_obj@images[[img_key]]@coordinates
  coords <- pick_coords_xy(coords_raw)
  # Align spots
  spot_names <- colnames(spatial_count)
  if (is.null(rownames(coords))) {
    rownames(coords) <- rownames(coords_raw)
  }
  if (!all(rownames(coords) %in% spot_names)) {
    rownames(coords) <- spot_names[seq_len(nrow(coords))]
  }
  common <- intersect(rownames(coords), spot_names)
  spatial_count <- spatial_count[, common, drop = FALSE]
  coords <- coords[common, , drop = FALSE]
  # Build query and run RCTD
  query <- SpatialRNA(coords, spatial_count)
  rctd_obj <- create.RCTD(
    query,
    reference,
    max_cores = max_cores,
    CELL_MIN_INSTANCE = 10
  )
  rctd_obj <- run.RCTD(rctd_obj, doublet_mode = doublet_mode)
  # Normalize weights and add to metadata
  weights <- rctd_obj@results$weights
  norm_weights <- normalize_weights(weights)
  # Add to Seurat object
  df <- as.data.frame(norm_weights)
  for (col_name in colnames(df)) {
    st_obj <- AddMetaData(st_obj, metadata = df[[col_name]], col.name = col_name)
  }
  # Add results
  results_df <- rctd_obj@results$results_df
  for (col_name in colnames(results_df)) {
    st_obj <- AddMetaData(st_obj, metadata = results_df[[col_name]], col.name = col_name)
  }
  return(list(st = st_obj, rctd = rctd_obj, weights = norm_weights))
}
