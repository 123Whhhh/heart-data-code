library(dbscan)
# cell_names <- unique(meta_df[, "cell_names"]) %>% sort
##########两两组合
comb <- combn(cell_names,2)
data <- NULL
for(i in 1:ncol(comb)){
  # 真实值估算
  single_A <- meta_df %>% filter(cell_names == comb[,i][1]) %>% dplyr::select(coord_x, coord_y)
  single_B <- meta_df %>% filter(cell_names == comb[,i][2]) %>% dplyr::select(coord_x, coord_y)
  
  nn = kNN(x = single_A, k = 1, query = single_B, search = "kdtree")
  QB_DA_T = median(nn$dist)
  
  nn = kNN(x = single_B, k = 1, query = single_A, search = "kdtree")
  QA_DB_T = median(nn$dist)
  
  # 随机抽样，用于p值计算
  QB_DA_F <- NULL
  QA_DB_F <- NULL
  for(j in 1:1000){
    sam_p = sample(x = 1:nrow(meta_df), size = nrow(single_A), replace = FALSE)
    single_A_rand = meta_df[sort(sam_p),] %>% dplyr::select(coord_x, coord_y)
    sam_p2 = sample(x = (1:nrow(meta_df))[! (1:nrow(meta_df) %in% sam_p)], size = nrow(single_B), replace = FALSE)
    single_B_rand = meta_df[sort(sam_p2),] %>% dplyr::select(coord_x, coord_y)
    
    nn_rand = kNN(x = single_A_rand, k = 1, query = single_B_rand, search = "kdtree")
    QB_DA = median(nn_rand$dist)
    QB_DA_F <- append(QB_DA_F, QB_DA)
    
    nn_rand = kNN(x = single_B_rand, k = 1, query = single_A_rand, search = "kdtree")
    QA_DB = median(nn_rand$dist)
    QA_DB_F <- append(QA_DB_F, QA_DB)
  }
  
  # 计算p值（校正）
  rank_QB_DA = sum(QB_DA_F <= QB_DA_T) + 1
  pvalue_QB_DA = rank_QB_DA / (1000 + 1)
  
  rank_QA_DB = sum(QA_DB_F <= QA_DB_T) + 1
  pvalue_QA_DB = rank_QA_DB / (1000 + 1)
  
  # 构造结果数据框，增加距离列
  tmp = data.frame(
    Predictor = comb[,i][2],
    Target = comb[,i][1],
    Pvalue = pvalue_QB_DA,
    MedianDist = QB_DA_T
  )
  data = rbind(tmp, data)
  
  tmp = data.frame(
    Predictor = comb[,i][1],
    Target = comb[,i][2],
    Pvalue = pvalue_QA_DB,
    MedianDist = QA_DB_T
  )
  data = rbind(tmp, data)
}
