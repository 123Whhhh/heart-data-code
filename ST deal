#' Calculate median nearest neighbor distances between two cell types
calculate_median_distance <- function(typeA_coords, typeB_coords) {
  nn <- kNN(
    x = typeA_coords,
    k = 1,
    query = typeB_coords,
    search = "kdtree"
  )
  return(median(nn$dist))
}
#' Perform permutation test for colocalization
permutation_test_colocalization <- function(
    meta_df,
    cell_type_a,
    cell_type_b,
    n_permutations = 1000
) {
  # Extract coordinates for each cell type
  coords_a <- meta_df %>%
    filter(cell_names == cell_type_a) %>%
    dplyr::select(coord_x, coord_y)
  
  coords_b <- meta_df %>%
    filter(cell_names == cell_type_b) %>%
    dplyr::select(coord_x, coord_y)
  # Observed distances
  dist_a_to_b <- calculate_median_distance(coords_a, coords_b)
  dist_b_to_a <- calculate_median_distance(coords_b, coords_a)
  # Permutation
  perm_dists_a_to_b <- numeric(n_permutations)
  perm_dists_b_to_a <- numeric(n_permutations)
  for (i in seq_len(n_permutations)) {
    # Randomly permute cell type labels
    perm_labels <- sample(meta_df$cell_names)
    perm_a <- meta_df %>%
      mutate(perm_labels = perm_labels) %>%
      filter(perm_labels == cell_type_a) %>%
      dplyr::select(coord_x, coord_y)
    perm_b <- meta_df %>%
      mutate(perm_labels = perm_labels) %>%
      filter(perm_labels == cell_type_b) %>%
      dplyr::select(coord_x, coord_y)
    if (nrow(perm_a) > 0 && nrow(perm_b) > 0) {
      perm_dists_a_to_b[i] <- calculate_median_distance(perm_a, perm_b)
      perm_dists_b_to_a[i] <- calculate_median_distance(perm_b, perm_a)
    } else {
      perm_dists_a_to_b[i] <- NA
      perm_dists_b_to_a[i] <- NA
    }
  }
  # Remove NAs
  perm_dists_a_to_b <- perm_dists_a_to_b[!is.na(perm_dists_a_to_b)]
  perm_dists_b_to_a <- perm_dists_b_to_a[!is.na(perm_dists_b_to_a)]
  # Calculate p-values (corrected)
  p_value_a_to_b <- (sum(perm_dists_a_to_b <= dist_a_to_b, na.rm = TRUE) + 1) /
    (length(perm_dists_a_to_b) + 1)
  
  p_value_b_to_a <- (sum(perm_dists_b_to_a <= dist_b_to_a, na.rm = TRUE) + 1) /
    (length(perm_dists_b_to_a) + 1)
  
  return(list(
    a_to_b = list(
      observed_dist = dist_a_to_b,
      p_value = p_value_a_to_b
    ),
    b_to_a = list(
      observed_dist = dist_b_to_a,
      p_value = p_value_b_to_a
    )
  ))
}

#' Run complete colocalization analysis
run_colocalization <- function(
    st_obj,
    cell_type_col = "second_type",
    n_permutations = 1000,
    min_cell_count = 1
) {
  # Extract metadata and coordinates
  coords <- GetTissueCoordinates(st_obj, cols = c("imagecol", "imagerow"), scale = NULL)
  coords <- cbind(rownames(coords), coords)
  colnames(coords) <- c("cellID", "coord_x", "coord_y")
  
  meta <- st_obj@meta.data[, c(1, which(colnames(st_obj@meta.data) == cell_type_col))]
  meta <- cbind(rownames(meta), meta)
  colnames(meta) <- c("cellID", "cell_names")
  
  # Merge and clean
  df <- left_join(meta, coords, by = "cellID") %>%
    na.omit()
  rownames(df) <- df$cellID
  df <- df[, -1]  # Remove cellID column
  
  # Filter by minimum cell count
  cell_counts <- table(df$cell_names)
  valid_cells <- names(cell_counts)[cell_counts >= min_cell_count]
  df <- df %>% filter(cell_names %in% valid_cells)
  
  cell_names <- sort(unique(df$cell_names))
  
  # Run pairwise colocalization
  results <- NULL
  combinations <- combn(cell_names, 2)
  
  for (i in seq_len(ncol(combinations))) {
    type_a <- combinations[1, i]
    type_b <- combinations[2, i]
    
    test_result <- permutation_test_colocalization(
      meta_df = df,
      cell_type_a = type_a,
      cell_type_b = type_b,
      n_permutations = n_permutations
    )
    
    # Add A -> B results
    results <- rbind(results, data.frame(
      Predictor = type_b,
      Target = type_a,
      Pvalue = test_result$a_to_b$p_value,
      MedianDist = test_result$a_to_b$observed_dist
    ))
    
    # Add B -> A results
    results <- rbind(results, data.frame(
      Predictor = type_a,
      Target = type_b,
      Pvalue = test_result$b_to_a$p_value,
      MedianDist = test_result$b_to_a$observed_dist
    ))
  }
  
  return(results)
}
