#' Create spatial plot for subset of cell types
plot_spatial_subset <- function(st_obj, colors, title = NULL) {
  p <- SpatialDimPlot(
    st_obj,
    group.by = "second_type",
    crop = FALSE,
    stroke = NA,
    label = FALSE,
    pt.size.factor = 9,
    image.alpha = 0,
    cols = colors
  )
  
  if (!is.null(title)) {
    p <- p + ggtitle(title)
  }
  
  # Add scale limits for consistency
  p <- p + scale_x_continuous(expand = c(0, 0))
  
  return(p)
}

#' Create colocalization heatmap with significance markers
plot_colocalization_heatmap <- function(
    coloc_data,
    output_file = NULL,
    title = NULL,
    color_breaks = c(0, 30, 60),
    colors = c("#D45590", "white", "#69AADB")
) {
  # Prepare MedianDist matrix
  df_dist <- coloc_data %>%
    pivot_wider(
      id_cols = Predictor,
      names_from = Target,
      values_from = MedianDist
    )
  
  mat_dist <- df_dist %>%
    column_to_rownames(var = "Predictor") %>%
    as.matrix()
  mat_dist[is.na(mat_dist)] <- NA
  
  # Prepare Pvalue matrix
  df_pval <- coloc_data %>%
    pivot_wider(
      id_cols = Predictor,
      names_from = Target,
      values_from = Pvalue
    )
  
  mat_pval <- df_pval %>%
    column_to_rownames(var = "Predictor") %>%
    as.matrix()
  mat_pval[is.na(mat_pval)] <- 1
  
  # Create significance symbols
  mat_symbol <- matrix("", nrow = nrow(mat_pval), ncol = ncol(mat_pval),
                       dimnames = dimnames(mat_pval))
  mat_symbol[mat_pval < 0.05] <- "*"
  mat_symbol[mat_pval < 0.01] <- "**"
  mat_symbol[mat_pval < 0.001] <- "***"
  
  # Color function
  col_fun <- colorRamp2(color_breaks, colors)
  
  # Ensure symmetric order
  row_order <- rownames(mat_dist)
  mat_dist <- mat_dist[row_order, row_order]
  
  # Create heatmap
  hm <- Heatmap(
    mat_dist,
    name = "MedianDist",
    col = col_fun,
    na_col = "grey90",
    rect_gp = gpar(col = "white", lwd = 1),
    width = ncol(mat_dist) * unit(6, "mm"),
    height = nrow(mat_dist) * unit(6, "mm"),
    row_names_gp = gpar(fontsize = 10),
    column_names_gp = gpar(fontsize = 10),
    column_names_rot = 45,
    cluster_rows = FALSE,
    cluster_columns = FALSE,
    cell_fun = function(j, i, x, y, width, height, fill) {
      symbol <- mat_symbol[i, j]
      if (symbol != "") {
        grid.text(symbol, x = x, y = y,
                  gp = gpar(fontsize = 12, fontface = "bold", col = "black"))
      }
    },
    heatmap_legend_param = list(
      title = "MedianDist",
      title_gp = gpar(fontsize = 9),
      labels_gp = gpar(fontsize = 7)
    )
  )
  
  # Save if output file provided
  if (!is.null(output_file)) {
    pdf(output_file, width = 9, height = 9)
    draw(hm)
    dev.off()
  }
  
  return(hm)
}
