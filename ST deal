.get_counts <- function(obj, assay_name) {
  # 先试 v5
  x <- tryCatch(
    GetAssayData(object = obj, assay = assay_name, slot = "counts"),
    error = function(e) NULL
  )
  if (!is.null(x)) return(x)
  # 回退 v4
  x <- tryCatch(
    GetAssayData(object = obj, assay = assay_name, slot = "counts"),
    error = function(e) NULL
  )
  if (!is.null(x)) return(x)
  stop(sprintf("无法从 assay '%s' 读取 counts（既不是 v5 layer 也不是 v4 slot）。", assay_name))
}

# ---- 选择并标准化坐标为两列(x, y) ----
.pick_coords_xy <- function(coords_df) {
  cand <- list(
    c("row","col"),
    c("x","y"),
    c("imagerow","imagecol")
  )
  sel <- NULL
  for (cn in cand) {
    if (all(cn %in% colnames(coords_df))) { sel <- cn; break }
  }
  if (is.null(sel)) {
    stop("在 image@coordinates 中没有找到可用的坐标列（期望 row/col 或 x/y 或 imagerow/imagecol）")
  }
  xy <- coords_df[, sel, drop = FALSE]
  colnames(xy) <- c("x","y")  # 统一成 x/y，RCTD 更稳
  xy
}

run_rctd_and_annotate <- function(st_obj, reference, doublet_mode = "full", max_cores = 1,
                                  spatial_assay = "Spatial") {
  # 1) 取原始 count（兼容 Seurat v4/v5）
  # st_obj  <- con_data
  # reference <- reference
  # doublet_mode = "doublet"
  # max_cores = 6
  # spatial_assay = "Spatial"
  spatial_count <- .get_counts(st_obj, spatial_assay)
  
  # 2) 取坐标（默认第一个 image）
  if (length(st_obj@images) < 1) stop("该 ST 对象没有 images。")
  img_key <- names(st_obj@images)[1]
  coords_raw <- st_obj@images[[img_key]]@coordinates
  coords <- .pick_coords_xy(coords_raw)
  
  # 3) 确保坐标的行名与 spot 名一致；必要时对齐顺序/交集
  spot_names <- colnames(spatial_count)
  if (is.null(rownames(coords))) rownames(coords) <- rownames(coords_raw)
  # 若行名不是 spot 名，就尝试强制对齐到 counts 的列名
  if (!all(rownames(coords) %in% spot_names)) {
    # 有时 coordinates 的行名恰好也是 spot 名；若不是，直接用 spot_names 覆盖
    rownames(coords) <- spot_names[seq_len(nrow(coords))]
  }
  # 只保留交集且按 counts 列顺序重排
  common <- intersect(rownames(coords), spot_names)
  spatial_count <- spatial_count[, common, drop = FALSE]
  coords <- coords[common, , drop = FALSE]
  
  # 4) 构建 query 并运行 RCTD
  query <- SpatialRNA(coords, spatial_count)
  rctd_obj <- create.RCTD(query, reference, max_cores = max_cores,CELL_MIN_INSTANCE = 10)
  rctd_obj <- run.RCTD(rctd_obj, doublet_mode = doublet_mode)
  # 5) 归一化权重并写回 ST 元数据
  weights <- rctd_obj@results$weights
  norm_weights <- normalize_weights(weights)
  df <- as.data.frame(norm_weights)
  for (col_name in colnames(df)) {
    st_obj <- AddMetaData(st_obj, metadata = df[[col_name]], col.name = col_name)
  }
  results_df <- rctd_obj@results$results_df
  for (col_name in colnames(results_df)) {
    st_obj <- AddMetaData(st_obj, metadata = results_df[[col_name]], col.name = col_name)
  }
  return(list(st = st_obj, rctd = rctd_obj, weights = norm_weights))
}
